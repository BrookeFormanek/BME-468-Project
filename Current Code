%% Part 3c: Zoomed 10-second EEG Segments (Filtered Data)

% Load Data
matData = load('BME468_Project.mat');
data = double(matData.dataMatrix);

fs = 1000;
[nSamples, nChan] = size(data);
t = (0:nSamples-1) / fs;

channelLabels = {
    'Ch1: tEEG P1', ...
    'Ch2: eEEG P1', ...
    'Ch3: tEEG P2', ...
    'Ch4: eEEG P2', ...
    'Ch5: tEEG Oz', ...
    'Ch6: eEEG Oz', ...
    'Ch7: EEG Pz'
};

% Bandpass Filter (1–30 Hz)
fLow  = 1;
fHigh = 30;
order = 4;

[b, a] = butter(order, [fLow fHigh] / (fs/2), 'bandpass');

filtered = zeros(size(data));
for ch = 1:nChan
