%% Part 3g: PSD of Selected Segments (1–30 Hz)

allRegions = [highRegions; lowRegions];
regionLabels = {'High 1','High 2','High 3','Low 1','Low 2','Low 3'};

nfft = 1024;

% ---- Find global max for consistent scaling ----
maxPSD = 0;

for r = 1:size(allRegions,1)
    mask = (t >= allRegions(r,1) & t <= allRegions(r,2));
    
    for ch = 1:7
        sig = filtered(mask,ch) - mean(filtered(mask,ch));
        [pxx,f] = pwelch(sig,hann(nfft),nfft/2,nfft,fs);
        
        band = (f >= 1 & f <= 30);
        maxPSD = max(maxPSD, max(pxx(band)));
    end
end

% ---- Plot ----
for r = 1:size(allRegions,1)
    
    mask = (t >= allRegions(r,1) & t <= allRegions(r,2));
    
    figure('Name',regionLabels{r},...
           'Units','normalized','OuterPosition',[0 0 1 1]);
    
    tiledlayout(4,2,'TileSpacing','compact','Padding','compact');
    
    for ch = 1:7
        
        sig = filtered(mask,ch) - mean(filtered(mask,ch));
        [pxx,f] = pwelch(sig,hann(nfft),nfft/2,nfft,fs);
        
        band = (f >= 1 & f <= 30);
        
        nexttile;
        plot(f(band), pxx(band), 'LineWidth',1.5);
        
        xlim([1 30]);
        ylim([0 maxPSD]);
        
        title(channelLabels{ch});
        xlabel('Hz'); ylabel('PSD');
        grid on;
    end
    
    % 8th panel
    nexttile;
    hold on;
    for ch = 1:7
        sig = filtered(mask,ch) - mean(filtered(mask,ch));
        [pxx,f] = pwelch(sig,hann(nfft),nfft/2,nfft,fs);
        band = (f >= 1 & f <= 30);
        plot(f(band), pxx(band));
    end
    
    xlim([1 30]);
    ylim([0 maxPSD]);
    title('All Channels');
