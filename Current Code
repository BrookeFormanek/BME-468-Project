end

% Define Regions (from Part 3b)

% ---- High activity regions ----
highRegions = [
    175 185;
    210 220;
    310 320
];

% ---- Low activity regions ----
lowRegions = [
    70 80;
    230 240;
    265 275
];

% Function to Plot a Region
function plot_region(t, filtered, region, channelLabels, labelText)

    tStart = region(1);
    tEnd   = region(2);
    
    mask = (t >= tStart) & (t <= tEnd);
    tSeg = t(mask);
    
    figure('Name', [labelText ' EEG Segment'], ...
           'Units', 'normalized', ...
           'OuterPosition', [0 0 1 1]);

    tiledlayout(4,2,'TileSpacing','compact','Padding','compact');

    % Plot each channel
    for i = 1:7
        nexttile;
        
        seg = filtered(mask, i);
        
        plot(tSeg, seg, 'LineWidth', 1.2);
        title(channelLabels{i}, 'FontSize', 10, 'FontWeight', 'bold');
        xlabel('Time (s)');
        ylabel('\muV');
        
        % Consistent scaling improves comparison
        p = prctile(seg, [1 99]);
        ylim([p(1)*1.2 p(2)*1.2]);
        
        grid on;
    end

    % 8th panel: mean across channels
    nexttile;
    meanSig = mean(filtered(mask, :), 2);
    plot(tSeg, meanSig, 'k', 'LineWidth', 1.5);
    title('Mean Across Channels', 'FontSize', 10, 'FontWeight', 'bold');
    xlabel('Time (s)');
    ylabel('\muV');
    grid on;

    sgtitle(sprintf('%s Activity (%d–%d s)', labelText, tStart, tEnd), ...
            'FontSize', 14, 'FontWeight', 'bold');
end

% Generate Figures

% ---- High Activity ----
for i = 1:size(highRegions,1)
    plot_region(t, filtered, highRegions(i,:), channelLabels, ...
        sprintf('High Activity Region %d', i));
end

% ---- Low Activity ----
for i = 1:size(lowRegions,1)
    plot_region(t, filtered, lowRegions(i,:), channelLabels, ...
        sprintf('Low Activity Region %d', i));
end

%% Part 3d: FFT Before and After Filtering

figure('Name', 'FFT Before vs After Filtering', ...
       'Units', 'normalized', ...
       'OuterPosition', [0 0 1 1]);

tiledlayout(4,2,'TileSpacing','compact','Padding','compact');

N = nSamples;
f = (0:N-1)*(fs/N);  % Frequency vector

% Only keep 1–100 Hz
freqMask = (f >= 1) & (f <= 100);

for i = 1:7
    
    % ---- Center signals ----
    raw = data(:, i) - mean(data(:, i));
    filt = filtered(:, i) - mean(filtered(:, i));
    
    % ---- FFT ----
    FFT_raw = fft(raw);
    FFT_filt = fft(filt);
    
    % ---- Power Spectrum ----
    P_raw = (abs(FFT_raw).^2) / N;
    P_filt = (abs(FFT_filt).^2) / N;
    
    % ---- Plot ----
    nexttile;
    
    plot(f(freqMask), P_raw(freqMask), 'Color', [0.6 0.6 0.6], 'LineWidth', 1.2);
    hold on;
    plot(f(freqMask), P_filt(freqMask), 'b', 'LineWidth', 1.2);
    
    title(channelLabels{i}, 'FontSize', 10, 'FontWeight', 'bold');
    xlabel('Frequency (Hz)');
    ylabel('Power (\muV^2)');
    
    xlim([1 100]);
    
    % Log scale helps visualization
    set(gca, 'YScale', 'log');
    
    grid on;
end

% 8th panel (summary across channels)
nexttile;
hold on;

for i = 1:7
    raw = data(:, i) - mean(data(:, i));
    filt = filtered(:, i) - mean(filtered(:, i));
    
    P_raw = (abs(fft(raw)).^2) / N;
    P_filt = (abs(fft(filt)).^2) / N;
    
    plot(f(freqMask), P_raw(freqMask), '--', 'Color', [0.7 0.7 0.7]);
    plot(f(freqMask), P_filt(freqMask), 'b');
end

title('All Channels Combined');
xlabel('Frequency (Hz)');
ylabel('Power (\muV^2)');
xlim([1 100]);
set(gca, 'YScale', 'log');
grid on;

sgtitle({'FFT Power Spectrum Before vs After 1–30 Hz Filter', ...
         'Signals Centered at Zero | 1–100 Hz Range'}, ...
         'FontSize', 14, 'FontWeight', 'bold');

%% Part 3e: FFT of Selected EEG Segments (1–30 Hz)

% ---- High activity regions ----
highRegions = [
    175 185;
    210 220;
    310 320
];

% ---- Low activity regions ----
lowRegions = [
    70 80;
    230 240;
    265 275
];

allRegions = [highRegions; lowRegions];
regionLabels = {
    'High 1','High 2','High 3', ...
    'Low 1','Low 2','Low 3'
};

% -------- First Pass: Find GLOBAL Y-LIMIT --------
maxPower = 0;

for r = 1:size(allRegions,1)
    
    tStart = allRegions(r,1);
    tEnd   = allRegions(r,2);
    mask = (t >= tStart) & (t <= tEnd);
    
    segData = filtered(mask, :);
    N = size(segData,1);
    f = (0:N-1)*(fs/N);
    freqMask = (f >= 1 & f <= 30);
    
    for ch = 1:nChan
        sig = segData(:, ch) - mean(segData(:, ch));
        P = (abs(fft(sig)).^2)/N;
        maxPower = max(maxPower, max(P(freqMask)));
    end
end

% -------- Second Pass: Plot Each Segment --------

for r = 1:size(allRegions,1)
    
    tStart = allRegions(r,1);
    tEnd   = allRegions(r,2);
    mask = (t >= tStart) & (t <= tEnd);
    segData = filtered(mask, :);
    
    N = size(segData,1);
    f = (0:N-1)*(fs/N);
    freqMask = (f >= 1 & f <= 30);

    figure('Name', regionLabels{r}, ...
           'Units', 'normalized', ...
           'OuterPosition', [0 0 1 1]);

    tiledlayout(4,2,'TileSpacing','compact','Padding','compact');

    for ch = 1:nChan
        
        sig = segData(:, ch) - mean(segData(:, ch));
        P = (abs(fft(sig)).^2)/N;
        
        nexttile;
        plot(f(freqMask), P(freqMask), 'LineWidth', 1.5);
        
        title(channelLabels{ch}, 'FontSize', 10, 'FontWeight', 'bold');
        xlabel('Frequency (Hz)');
        ylabel('Power (\muV^2)');
        
        xlim([1 30]);
        ylim([0 maxPower]);
        
        grid on;
    end

    % 8th panel: mean power across channels
    nexttile;
    hold on;
    
    for ch = 1:nChan
        sig = segData(:, ch) - mean(segData(:, ch));
        P = (abs(fft(sig)).^2)/N;
        plot(f(freqMask), P(freqMask));
    end
    
    title('All Channels Overlay');
    xlabel('Frequency (Hz)');
    ylabel('Power (\muV^2)');
    xlim([1 30]);
    ylim([0 maxPower]);
    grid on;

    sgtitle(sprintf('FFT Power (%s) — %d–%d s', ...
        regionLabels{r}, tStart, tEnd), ...
        'FontSize', 14, 'FontWeight', 'bold');
end

